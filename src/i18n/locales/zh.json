      "description": "\u975e\u5e38\u9002\u5408\u521a\u63a5\u89e6\u516c\u5171\u6f14\u8bb2\u7684\u5c0f\u5c0f\u5b66\u4e60\u8005\u3002\u9488\u9f39\u542f\u8499\u73ed\u5e2e\u52a9\u5b69\u5b50\u4eec\u5728\u8f7b\u677e\u6109\u5feb\u7684\u6c1b\u56f4\u4e2d\u9010\u6e10\u9002\u5e94\u516c\u5f00\u8868\u8fbe\u3002\u901a\u8fc7\u8da3\u5473 Show & Tell (\u5c55\u793a\u4e0e\u6f14\u8bf4)\u3001\u751f\u52a8\u7684\u89d2\u8272\u626e\u6f14\u548c\u5bcc\u6709\u6e38\u620f\u611f\u7684\u4e92\u52a8\uff0c\u5b69\u5b50\u4eec\u5c06\u5b66\u4f1a\u81ea\u4fe1\u3001\u6d41\u5229\u5730\u4ecb\u7ecd\u81ea\u5df1\u3001\u5206\u4eab\u7b80\u5355\u60f3\u6cd5\u5e76\u4e50\u5728\u5176\u4e2d\u3002",
      "keyOutcome": "\u5efa\u7acb\u8868\u8fbe\u5174\u8da3\u4e0e\u6d88\u9664\u516c\u5f00\u8bf4\u8bdd\u7684\u6050\u60e7",
      "outcomes": [
        "\u5927\u65b9\u5f97\u4f53\u5730\u4ecb\u7ecd\u81ea\u5df1\uff0c\u5e76\u5411\u540c\u4f34\u5206\u4eab\u8da3\u5473\u4e2a\u4eba\u7279\u8d28",
        "\u5e26\u7740\u6781\u9ad8\u70ed\u60c5\u53c2\u4e0e Show & Tell \u5c55\u793a\u4e92\u52a8\u73af\u8282",
        "\u5728\u6f14\u8bb2\u65f6\u4fdd\u6301\u81ea\u7136\u8212\u9002\u7684\u773c\u795e\u63a5\u89e6\u4e0e\u5fae\u7b11\u7ad9\u59ff",
        "\u57f9\u517b\u57fa\u7840\u7684\u97f3\u91cf\u63a7\u5236\u3001\u58f0\u97f3\u6295\u5f71\u4e0e\u53e3\u9f7f\u6e05\u6670\u5ea6"
      ]
    },
    "kasuari": {
      "name": "\u9e64\u9e35\u8fdb\u9636\u73ed (Kasuari)",
      "subtitle": "\u6211\u80fd\u81ea\u4fe1\u3001\u7cbe\u5f69\u5730\u8bb2\u8ff0\u6545\u4e8b\u3002",
      "description": "\u6fc0\u53d1\u5b69\u5b50\u4eec\u7684\u521b\u610f\u601d\u7ef4\u4e0e\u8868\u8fbe\u4fe1\u5fc3\u3002\u901a\u8fc7\u8bb2\u6545\u4e8b\u5927\u8d5b\u3001\u751f\u52a8\u7684\u620f\u5267\u626e\u6f14\u548c\u60c5\u5883\u6c9f\u901a\u6f14\u7ece\uff0c\u5f15\u5bfc\u5b69\u5b50\u4eec\u5b66\u4f1a\u6574\u7406\u601d\u7ef4\u3001\u6709\u903b\u8f91\u5730\u7ec4\u7ec7\u8bdd\u8bed\u3001\u6293\u4f4f\u542c\u4f17\u6ce8\u610f\u529b\uff0c\u8ba9\u8bed\u8a00\u8868\u8fbe\u53d8\u5f97\u6781\u5bcc\u753b\u9762\u611f\u4e0e\u8868\u73b0\u529b\u3002",
      "keyOutcome": "\u638c\u63e1\u6545\u4e8b\u67b6\u6784\u4e0e\u521b\u610f\u8868\u8fbe\u80fd\u529b",
      "outcomes": [
        "\u638c\u63e1\u7ecf\u5178\u6545\u4e8b\u4e09\u6bb5\u5f0f\u67b6\u6784\uff08\u5f15\u5165\u3001\u9ad8\u6f6e\u3001\u7ed3\u5c3e\uff09",
        "\u7075\u6d3b\u53d8\u6362\u8bed\u97f3\u8bed\u8c03\u3001\u97f3\u91cf\u4e0e\u8bed\u901f\uff0c\u8425\u9020\u751f\u52a8\u6c1b\u56f4",
        "\u719f\u7ec3\u4e14\u81ea\u7136\u5730\u8fd0\u7528\u80a2\u4f53\u8bed\u8a00\u4e0e\u9762\u90e8\u8868\u60c5\u8f85\u52a9\u6f14\u8bb2",
        "\u57f9\u517b\u79ef\u6781\u503e\u542c\u7684\u80fd\u529b\uff0c\u5e76\u5bf9\u540c\u4f34\u7684\u6f14\u8bb2\u7ed9\u4e88\u6e29\u548c\u53cd\u9988"
      ]
    },
    "bear": {
      "name": "\u5e7c\u718a\u7cbe\u82f1\u73ed (Bear)",
      "subtitle": "\u6211\u80fd\u6761\u7406\u6e05\u6670\u5730\u5c55\u793a\u60f3\u6cd5\uff0c\u7528\u8a00\u8bed\u5e26\u6765\u6539\u53d8\u3002",
      "description": "\u4e13\u4e3a\u51c6\u5907\u597d\u8fdb\u884c\u6df1\u5ea6\u6f14\u8bb2\u7684\u5b69\u5b50\u8bbe\u8ba1\u3002\u672c\u8bfe\u7a0b\u805a\u7126\u4e8e\u6709\u6df1\u5ea6\u3001\u6709\u8bf4\u670d\u529b\u7684\u89c2\u70b9\u9648\u8ff0\u3002\u5b69\u5b50\u4eec\u5c06\u63a2\u8ba8 STEAM\uff08\u79d1\u5b66\u3001\u6280\u672f\u3001\u5de5\u7a0b\u3001\u827a\u672f\u3001\u6570\u5b66\uff09\u548c\u53ef\u6301\u7eed\u53d1\u5c55\u7b49\u8de8\u5b66\u79d1\u524d\u6cbf\u8bdd\u9898\uff0c\u5168\u9762\u9524\u70bc\u903b\u8f91\u601d\u8fa8\u3001 PPT\u8f85\u52a9\u6f14\u793a\u4e0e\u8bf4\u670d\u5f0f\u6c9f\u901a\u80fd\u529b\u3002",
      "keyOutcome": "\u5353\u8d8a\u7684\u6b63\u5f0f\u6f14\u8bb2\u7d20\u517b\u4e0e\u601d\u8fa8\u8bf4\u670d\u529b",
      "outcomes": [
        "\u72ec\u7acb\u8bbe\u8ba1\u5e76\u914d\u5408 PPT \u5927\u7eb2\u8fdb\u884c\u6b63\u5f0f\u4e14\u5f97\u4f53\u7684\u6f14\u8bb2\u6c47\u62a5",
        "\u9ad8\u6548\u6574\u5408\u4e8b\u5b9e\u8bba\u636e\uff0c\u9610\u8ff0\u5177\u6709\u903b\u8f91\u4e25\u5bc6\u6027\u548c\u8bf4\u670d\u529b\u7684\u89c2\u70b9",
        "\u9488\u5bf9\u591a\u5143\u5316\u7684\u6559\u80b2\u53ca\u793e\u4f1a\u8bdd\u9898\u8fdb\u884c\u6d41\u7545\u3001\u654f\u6377\u7684\u5373\u5174\u6f14\u8bb2",
        "\u5728\u6f14\u8bb2\u540e\u5927\u65b9\u3001\u4e13\u4e1a\u5730\u89e3\u7b54\u73b0\u573a\u542c\u4f17\u7684\u63d0\u95ee\u4e0e\u53cd\u9988\u610f\u89c1"
      ]
    }
  },
  "faqs_list": [
    {
      "question": "\u4f60\u4eec\u62db\u6536\u54ea\u4e2a\u5e74\u9f84\u6bb5\u7684\u5b66\u751f\uff1f",
      "answer": "\u6211\u4eec\u4e3a 5 \u81f3 14 \u5c81\u7684\u5b69\u5b50\u63d0\u4f9b\u5b9a\u5236\u5316\u7684\u5c0f\u73ed\u8bfe\u7a0b\u3002\u5b66\u751f\u6309\u5e74\u9f84\u548c\u793e\u4ea4/\u8ba4\u77e5\u53d1\u5c55\u5206\u4e3a\uff1a\u9488\u9f39\u542f\u8499\u73ed\uff085-7 \u5c81\uff09\u3001\u9e64\u9e35\u8fdb\u9636\u73ed\uff088-10 \u5c81\uff09\u548c\u5e7c\u718a\u7cbe\u82f1\u73ed\uff0811-14 \u5c81\uff09\uff0c\u4ee5\u786e\u4fdd\u6559\u5b66\u6750\u6599\u4e0e\u8ba8\u8bba\u4e3b\u9898\u6700\u9002\u5408\u4ed6\u4eec\u7684\u6210\u957f\u9636\u6bb5\u3002"
    },
    {
      "question": "\u8bfe\u7a0b\u662f\u5728\u7ebf\u6388\u8bfe\u8fd8\u662f\u7ebf\u4e0b\u5b9e\u4f53\u8bfe\uff1f",
      "answer": "\u6211\u4eec\u91c7\u7528\u9ad8\u5ea6\u4e92\u52a8\u7684\u5b9e\u65f6\u5728\u7ebf\u6388\u8bfe\u6a21\u5f0f\uff0c\u5b69\u5b50\u4eec\u5728\u5bb6\u4e2d\u5373\u53ef\u5b89\u5168\u3001\u8212\u9002\u5730\u52a0\u5165\u8bfe\u5802\u3002\u6211\u4eec\u7684\u6570\u5b57\u8bfe\u5802\u4e13\u4e3a\u513f\u7ae5\u5f00\u53d1\uff0c\u4fdd\u6301\u8d85\u4f4e\u7684\u5c0f\u73ed\u4eba\u6570\uff0c\u8f85\u4ee5\u6d3b\u8dc3\u7684\u5b9e\u64cd\u6f14\u8bb2\u7ec3\u4e60\u3001\u6570\u5b57\u767d\u677f\u548c\u6f14\u8bb2\u6e38\u620f\uff0c\u786e\u4fdd\u6bcf\u4e2a\u5b69\u5b50\u90fd\u9ad8\u5ea6\u4e13\u6ce8\u3001\u5f97\u5230\u5145\u5206\u953b\u70bc\u3002"
    },
    {
      "question": "\u4e00\u4e2a\u5c0f\u73ed\u91cc\u901a\u5e38\u6709\u591a\u5c11\u4e2a\u5b69\u5b50\uff1f",
      "answer": "\u6211\u4eec\u4e25\u683c\u63a7\u5236\u5e08\u751f\u6bd4\u4f8b\uff0c\u6bcf\u4e2a\u73ed\u7ea7\u4ec5\u9650 6 \u81f3 8 \u540d\u5b66\u5458\u3002\u8fd9\u786e\u4fdd\u4e86\u4e3b\u8bb2\u8001\u5e08\u80fd\u591f\u7ed9\u4e88\u6bcf\u4e00\u4e2a\u5b69\u5b50\u6781\u5176\u4e2a\u6027\u5316\u7684\u6e29\u548c\u6307\u5bfc\u3001\u6bcf\u5802\u8bfe\u6709\u591a\u6b21\u4e0a\u53f0\u5f00\u9ea6\u8868\u8fbe\u7684\u673a\u4f1a\uff0c\u5e76\u80fd\u5728\u8bfe\u540e\u63d0\u4f9b\u8be6\u7ec6\u3001\u6e29\u548c\u7684\u8fdb\u6b65\u53cd\u9988\u3002"
    },
    {
      "question": "\u5b69\u5b50\u62a5\u540d\u9700\u8981\u6709\u516c\u5171\u6f14\u8bb2\u7ecf\u9a8c\u5417\uff1f",
      "answer": "\u5b8c\u5168\u4e0d\u9700\u8981\uff01\u6211\u4eec\u8d85\u8fc7 80% \u7684\u65b0\u5b66\u5458\u90fd\u662f\u96f6\u57fa\u7840\uff0c\u4e14\u5927\u591a\u4f34\u6709\u4e0d\u540c\u7a0b\u5ea6\u7684\u7f9e\u602f\u3002\u6211\u4eec\u4e13\u4e1a\u7684\u9636\u68af\u5f0f\u6210\u957f\u8bfe\u7a0b\u65e8\u5728\u6e29\u548c\u5730\u5f15\u5bfc\u5b69\u5b50\u4eec\u4ece\u8bf4\u51fa\u7b80\u5355\u7684\u5b8c\u6574\u53e5\u5b50\uff0c\u4e00\u6b65\u6b65\u873f\u53d8\u5230\u53d1\u8868\u5b8c\u6574\u7684\u7ed3\u6784\u5316\u6f14\u8bb2\uff0c\u73cd\u89c6\u5b69\u5b50\u7684\u6bcf\u4e00\u70b9\u5fae\u5c0f\u8fdb\u6b65\u3002"
    },
    {
      "question": "\u4e00\u4e2a\u5b66\u671f\u6709\u591a\u957f\uff1f\u8d39\u7528\u4e2d\u5305\u542b\u54ea\u4e9b\u5185\u5bb9\uff1f",
      "answer": "\u6807\u51c6\u5b66\u671f\u4e3a\u671f 10 \u5468\uff0c\u6bcf\u5468\u5305\u542b\u4e00\u6b21\u9ad8\u4e92\u52a8\u76f4\u64ad\u8bfe\u3002\u5b66\u8d39\u4e2d\u5df2\u5305\u542b\uff1a\u5168\u5957\u5b9a\u5236\u6570\u5b57\u7ec3\u4e60\u518c\u3001\u6bcf\u5468\u7531\u8587\u8001\u5e08\u64b0\u5199\u7684\u8be6\u7ec6\u5bb6\u957f\u53cd\u9988\u62a5\u544a\u5361\u3001\u6570\u5b57\u6f14\u8bb2\u8bfe\u540e\u6e38\u620f\u6743\u9650\u3001\u4ee5\u53ca\u5728\u5b66\u671f\u5706\u6ee1\u7ed3\u675f\u65f6\u9881\u53d1\u7684\u7cbe\u7f8e\u4e2a\u6027\u5316\u7ed3\u4e1a\u8bc1\u4e66\u3002"
    }
  ]
}
